{
  "name": "peeler",
  "description": "parser for only bracket.",
  "version": "1.4.0",
  "author": "elzup",
  "repository": "elzup/peeler",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "@types/node": "^22.0.0",
    "eslint": "^8.34.0",
    "eslint-config-nzap": "^7.0.0",
    "jest": "^29.4.2",
    "prettier": "^2.8.4",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "brace",
    "bracket",
    "parser",
    "syntax"
  ],
  "license": "MIT",
  "lint-staged": {
    "scripts/**/*.ts": [
      "eslint --fix",
      "git add"
    ]
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "deploy": "yarn build && yarn publish",
    "lint": "eslint --ext .ts src",
    "test": "yarn lint && jest",
    "prepublishOnly": "yarn build"
  }
}
